#!/usr/bin/env node
// create-tool.mjs â€” Scaffold a new Arcana tool under ./tools with self-managed settings.
// Usage: node skills/create_tool/scripts/create-tool.mjs <tool-name> [--desc "Description"] [--with-plugin]
import { mkdirSync, writeFileSync, existsSync, readFileSync, renameSync } from 'node:fs';
import { join } from 'node:path';

function toHyphenCase(s){
  return String(s||'').trim().toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,'');
}
function toTitleCase(s){
  return toHyphenCase(s).split('-').map(w=> w ? (w[0].toUpperCase()+w.slice(1)) : '').join(' ');
}
function toPascal(s){
  return toHyphenCase(s).split('-').map(w=> w ? (w[0].toUpperCase()+w.slice(1)) : '').join('');
}

function write(p, s){ writeFileSync(p, s, { encoding: 'utf8', flag: 'wx' }); }

function main(){
  const a = process.argv.slice(2);
  if (!a[0] || a[0].startsWith('--')){
    console.error('Usage: create-tool.mjs <tool-name> [--desc "Description"] [--with-plugin]');
    process.exit(2);
  }
  const nameRaw = a[0];
  let desc = 'Custom tool';
  let withPlugin = false;
  for (let i=1;i<a.length;i++){
    const t = a[i];
    if (t === '--with-plugin'){ withPlugin = true; continue; }
    if (t === '--desc'){ desc = String(a[i+1]||desc); i++; continue; }
  }

  const name = toHyphenCase(nameRaw);
  if (!name) { console.error('Invalid tool name'); process.exit(2); }

  const root = process.cwd();
  const toolsDir = join(root, 'tools');
  const dir = join(toolsDir, name);
  if (existsSync(dir)) { console.error('Tool already exists:', dir); process.exit(1); }
  mkdirSync(dir, { recursive: true });

  const Label = toTitleCase(name);
  const Pascal = toPascal(name);

  // index.js
  const indexJs = `// ${name}/index.js â€” Arcana tool (ESM). In-process; no CLI/env dependencies.\n`+
  `import { getSettings, updateSettings } from './settings.js';\n\n`+
  `export function createTool(opts = {}){\n`+
  `  const name = String(opts.name||'${name}');\n`+
  `  const label = String(opts.label||'${Label}');\n`+
  `  const description = String(opts.description||'${desc.replace(/`/g,'\\`')}');\n`+
  `  return {\n`+
  `    name,\n`+
  `    label,\n`+
  `    description,\n`+
  `    // Expand as needed; keep permissive by default and validate in execute()\n`+
  `    parameters: { type:'object', properties:{}, additionalProperties:true },\n`+
  `    /**\n`+
  `     * Execute the tool.\n`+
  `     * @param {string} callId - unique call id\n`+
  `     * @param {object} args - input arguments\n`+
  `     * @returns {{ content: Array, details: object }}\n`+
  `     */\n`+
  `    async execute(callId, args){\n`+
  `      // Example: handle settings updates in-band\n`+
  `      if (args && args.__settings && typeof args.__settings === 'object'){\n`+
  `        await updateSettings(args.__settings);\n`+
  `        return { content:[{ type:'text', text:'Settings updated.' }], details:{ ok:true, updated:true } };\n`+
  `      }\n`+
  `      const cfg = await getSettings();\n`+
  `      // TODO: implement core behavior here using args + cfg\n`+
  `      return { content:[{ type:'text', text:'${Label} is ready. Implement execute().' }], details:{ ok:true, settings: cfg } };\n`+
  `    }\n`+
  `  };\n`+
  `}\n\n`+
  `export default createTool;\n`;

  // settings.js
  const settingsJs = `// ${name}/settings.js â€” Local settings storage (gitignored).\n`+
  `import { readFileSync, writeFileSync, renameSync } from 'node:fs';\n`+
  `import { join, dirname } from 'node:path';\n`+
  `import { fileURLToPath } from 'node:url';\n`+
  `const __dirname = dirname(fileURLToPath(import.meta.url));\n`+
  `const PATH = join(__dirname, 'settings.json');\n`+
  `export async function getSettings(){\n`+
  `  try { const s = readFileSync(PATH, 'utf8'); return JSON.parse(s||'{}'); }\n`+
  `  catch { return {}; }\n`+
  `}\n`+
  `export async function updateSettings(patch = {}){\n`+
  `  const cur = await getSettings();\n`+
  `  const next = { ...cur, ...patch };\n`+
  `  const tmp = PATH + '.tmp';\n`+
  `  writeFileSync(tmp, JSON.stringify(next, null, 2) + '\n', 'utf8');\n`+
  `  try { renameSync(tmp, PATH); } catch { /* ignore */ }\n`+
  `  return next;\n`+
  `}\n`+
  `export default { getSettings, updateSettings };\n`;

  // .gitignore
  const gitignore = 'settings.json\n';

  write(join(dir, 'index.js'), indexJs);
  write(join(dir, 'settings.js'), settingsJs);
  write(join(dir, '.gitignore'), gitignore);

  if (withPlugin){
    const pluginsDir = join(root, 'plugins');
    mkdirSync(pluginsDir, { recursive: true });
    const pluginJs = `export default async function(pi){\n  const { default: createTool } = await import('../tools/${name}/index.js');\n  pi.registerTool(createTool());\n}\n`;
    write(join(pluginsDir, `${name}.js`), pluginJs);
  }

  console.log('Created tool at', dir, withPlugin ? 'and plugin at ./plugins/'+name+'.js' : '');
}

main();
